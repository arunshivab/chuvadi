<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <AssemblyName>Chuvadi.Pdf.Reader</AssemblyName>
    <RootNamespace>Chuvadi.Pdf.Reader</RootNamespace>
    <Description>
      High-level reader facade over the Chuvadi PDF library. Exposes a
      single IPdfReader interface that interactive PDF reader applications
      (Blazor WebAssembly, WPF, etc.) can depend on for opening documents,
      rendering pages and thumbnails as SVG, traversing outlines, streaming
      search matches, and reading text-run geometry. Concrete
      ChuvadiPdfReader implementation included; mockable via the interface
      for testing.
    </Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Chuvadi.Pdf.Documents\Chuvadi.Pdf.Documents.csproj" />
    <ProjectReference Include="..\Chuvadi.Pdf.Forms\Chuvadi.Pdf.Forms.csproj" />
    <ProjectReference Include="..\Chuvadi.Pdf.Rendering.DisplayList\Chuvadi.Pdf.Rendering.DisplayList.csproj" />
    <ProjectReference Include="..\Chuvadi.Pdf.Svg\Chuvadi.Pdf.Svg.csproj" />
  </ItemGroup>

</Project>
