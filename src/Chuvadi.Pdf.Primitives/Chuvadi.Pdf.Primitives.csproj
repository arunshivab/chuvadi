<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <AssemblyName>Chuvadi.Pdf.Primitives</AssemblyName>
    <RootNamespace>Chuvadi.Pdf.Primitives</RootNamespace>
    <Description>
      Core primitive types for the Chuvadi PDF library.
      Includes the byte-level tokenizer, PDF primitive object hierarchy
      (PdfNumber, PdfName, PdfString, PdfArray, PdfDictionary, PdfStream,
      PdfBoolean, PdfNull, PdfReference), parsing helpers, and
      memory-efficient buffer utilities.

      This project has zero dependencies — not even on other Chuvadi projects.
      Everything in the library ultimately depends on this project.
    </Description>
    <!-- Unsafe blocks: needed for Span/Memory hot paths in the tokenizer -->
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

</Project>
