<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>Chuvadi.Pdf.Images.Jpeg</AssemblyName>
    <RootNamespace>Chuvadi.Pdf.Images.Jpeg</RootNamespace>
    <Description>
      Pure-C# baseline DCT JPEG encoder. RGB → YCbCr → 8x8 DCT →
      quantization → zigzag → Huffman → JFIF container. Used by the
      SVG renderer for embedding raster images. Phase 2.1.
    </Description>
    <PackageId>Chuvadi.Pdf.Images.Jpeg</PackageId>
  </PropertyGroup>
</Project>
