<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <AssemblyName>Chuvadi.Benchmarks</AssemblyName>
    <RootNamespace>Chuvadi.Benchmarks</RootNamespace>
    <IsPackable>false</IsPackable>
    <!-- BenchmarkDotNet pulls in transitive deps with internal XML doc gaps. -->
    <NoWarn>$(NoWarn);CS1591</NoWarn>
    <!-- Benchmarks require Release configuration to be meaningful. -->
    <ServerGarbageCollection>true</ServerGarbageCollection>
    <ConcurrentGarbageCollection>true</ConcurrentGarbageCollection>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="BenchmarkDotNet" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Chuvadi.Pdf.Fonts.Woff2\Chuvadi.Pdf.Fonts.Woff2.csproj" />
    <ProjectReference Include="..\..\src\Chuvadi.Pdf.Documents\Chuvadi.Pdf.Documents.csproj" />
    <ProjectReference Include="..\..\src\Chuvadi.Pdf.Authoring\Chuvadi.Pdf.Authoring.csproj" />
  </ItemGroup>

</Project>
