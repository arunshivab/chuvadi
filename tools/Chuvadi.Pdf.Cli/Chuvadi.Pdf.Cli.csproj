<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <AssemblyName>chuvadi</AssemblyName>
    <RootNamespace>Chuvadi.Pdf.Cli</RootNamespace>
    <OutputType>Exe</OutputType>
    <Description>
      Command-line interface for the Chuvadi PDF library.
      Maximal verb surface: end-user operations plus low-level introspection.

      User verbs:
        info, render, watermark, redact, form-fill, extract-text,
        outlines, merge, split, delete, rotate

      Debug verbs:
        tokenize, dump-objects, parse-content, decode-stream,
        inspect-xref, validate-fonts
    </Description>
    <IsPackable>false</IsPackable>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Chuvadi.Pdf.Primitives\Chuvadi.Pdf.Primitives.csproj" />
    <ProjectReference Include="..\..\src\Chuvadi.Pdf.Filters\Chuvadi.Pdf.Filters.csproj" />
    <ProjectReference Include="..\..\src\Chuvadi.Pdf.Objects\Chuvadi.Pdf.Objects.csproj" />
    <ProjectReference Include="..\..\src\Chuvadi.Pdf.IO\Chuvadi.Pdf.IO.csproj" />
    <ProjectReference Include="..\..\src\Chuvadi.Pdf.Documents\Chuvadi.Pdf.Documents.csproj" />
    <ProjectReference Include="..\..\src\Chuvadi.Pdf.Fonts\Chuvadi.Pdf.Fonts.csproj" />
    <ProjectReference Include="..\..\src\Chuvadi.Pdf.Content\Chuvadi.Pdf.Content.csproj" />
    <ProjectReference Include="..\..\src\Chuvadi.Pdf.Text\Chuvadi.Pdf.Text.csproj" />
    <ProjectReference Include="..\..\src\Chuvadi.Pdf.Operations\Chuvadi.Pdf.Operations.csproj" />
    <ProjectReference Include="..\..\src\Chuvadi.Pdf.Graphics\Chuvadi.Pdf.Graphics.csproj" />
    <ProjectReference Include="..\..\src\Chuvadi.Pdf.Images\Chuvadi.Pdf.Images.csproj" />
    <ProjectReference Include="..\..\src\Chuvadi.Pdf.Fonts.Rendering\Chuvadi.Pdf.Fonts.Rendering.csproj" />
    <ProjectReference Include="..\..\src\Chuvadi.Pdf.Rendering\Chuvadi.Pdf.Rendering.csproj" />
    <ProjectReference Include="..\..\src\Chuvadi.Pdf.Watermark\Chuvadi.Pdf.Watermark.csproj" />
    <ProjectReference Include="..\..\src\Chuvadi.Pdf.Redaction\Chuvadi.Pdf.Redaction.csproj" />
    <ProjectReference Include="..\..\src\Chuvadi.Pdf.Forms\Chuvadi.Pdf.Forms.csproj" />
  </ItemGroup>

</Project>
